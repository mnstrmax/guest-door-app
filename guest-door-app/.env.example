# Home Assistant Basis-URL (lokal erreichbar, z. B. http://homeassistant.local:8123)
HA_URL=http://homeassistant.local:8123

# Long-Lived Access Token: Home Assistant -> Profil (unten links, dein Benutzername)
# -> ganz nach unten scrollen -> "Sicherheit" -> "Langlebige Zugriffstoken" -> Token erstellen
HA_TOKEN=

# Entity-ID des Sensors, der "on" wird, wenn an der Ring-Gegensprechanlage geklingelt wird.
# Finden unter: Entwicklerwerkzeuge -> Zustände -> nach "ding" oder dem Gerätenamen filtern.
DOORBELL_ENTITY_ID=binary_sensor.your_doorbell_ding

# Entity-ID des Ring Intercom (Haustür). In Home Assistant als "lock"-Entity eingebunden.
RING_INTERCOM_ENTITY_ID=lock.your_ring_intercom
# Service zum Öffnen: i.d.R. "unlock". Manche Ring-Intercom-Setups unterstützen kein "open"
# (führt dann zu einem 500er) - im Zweifel bei "unlock" bleiben.
RING_INTERCOM_SERVICE=unlock

# Entity-ID des Nuki Smart Locks (Wohnungstür). Ebenfalls Domain "lock".
NUKI_ENTITY_ID=lock.your_nuki_lock
# Service zum Öffnen: "unlock" (nur entriegeln) oder "open" (Nuki "Auf" - entriegeln + Türöffner, falls konfiguriert)
NUKI_SERVICE=unlock

# Optional: Lichter, die beim Öffnen der Wohnungstür automatisch angehen. Leer lassen zum Deaktivieren.
HALLWAY_LIGHT_ENTITY_ID=
GUESTROOM_LIGHT_ENTITY_ID=

# Optional: Klingelschild-Name (Eigenname, bleibt in jeder Sprache unverändert).
# Leer lassen für einen generischen Text ohne Namen.
BELL_LABEL=

# Optional: Stockwerk und Seite der Wohnungstür, strukturiert statt Freitext - damit
# das Frontend daraus in jeder Sprache eine korrekt übersetzte Anleitung baut
# (z.B. "3rd floor, on the right" / "au 3e étage, à droite").
# APARTMENT_FLOOR: Stockwerk als Zahl, 0 = Erdgeschoss, 1 = 1. OG, usw.
# APARTMENT_SIDE: left/links, right/rechts oder middle/mitte/mittig. Leer lassen zum Weglassen.
APARTMENT_FLOOR=
APARTMENT_SIDE=

# Optional: analog für das Zimmer des Gasts (Nummer + Seite).
ROOM_NUMBER=
ROOM_SIDE=

# Passwort für die /admin-Seite (Gäste mit Name/PIN/Zeitraum verwalten). Erforderlich.
ADMIN_PASSWORD=

# Voller notify-Service-Name für Push-Benachrichtigungen an dein Handy (HA-Companion-App),
# z.B. "mobile_app_dein_iphone_name" (Teil nach "notify."). Leer lassen zum Deaktivieren.
NOTIFY_SERVICE=

# Optional: Entity-ID eines input_boolean-Helfers in Home Assistant. Die App setzt ihn auf
# "on", solange sie auf ein Klingeln wartet, und wieder auf "off", sobald das erledigt ist.
# Damit kann eine eigene Klingel-Automation (z.B. allgemeine Push-Benachrichtigung bei jedem
# Klingeln) als zusätzliche Bedingung prüfen, ob die App den Ring schon selbst verarbeitet,
# und dann keine doppelte Benachrichtigung schicken. Leer lassen zum Deaktivieren.
APP_ACTIVE_ENTITY_ID=

# Optional: Zimmersteuerung für Rückkehrgäste (wer schon einmal komplett eingecheckt und
# "Alles in Ordnung" bestätigt hat, bekommt bei der nächsten PIN-Eingabe ein Menü mit der
# Wahl zwischen "Türen nochmal öffnen" und "Zimmer steuern"). Ist keine der drei Entities
# gesetzt, entfällt das Menü und Rückkehrgäste durchlaufen weiterhin normal den
# Klingel-Ablauf. GUESTROOM_CLIMATE_ENTITY_ID = Heizung (Domain "climate").
GUESTROOM_CLIMATE_ENTITY_ID=
GUESTROOM_CEILING_LIGHT_ENTITY_ID=
GUESTROOM_FLOOR_LIGHT_ENTITY_ID=

# Optional: privater Airbnb-Kalender-Export-Link (Airbnb -> Kalender -> Verfügbarkeit ->
# "Mit anderer Website verbinden" -> Link kopieren, muss auf .ics enden). Ist er gesetzt,
# importiert die App neue Reservierungen automatisch stündlich als Gäste: Check-in/Check-out
# aus dem Kalender, PIN = letzte 4 Ziffern der Telefonnummer, die Airbnb im Feed mitliefert
# (einen Namen liefert Airbnb seit 2019 aus Datenschutzgründen nicht mehr - der Name landet
# vorerst als Platzhalter "Airbnb-Gast" in der Gästeliste, du kannst ihn in /admin anpassen).
# Manuell angelegte Gäste werden vom Sync nie verändert. Der Link ist geheim wie ein
# Passwort - genau wie andere persönliche Werte NIE im Quellcode/Git speichern.
AIRBNB_ICAL_URL=

# Uhrzeit, die für automatisch importierte Reservierungen als Check-in/Check-out
# angenommen wird (Airbnb liefert im Kalender nur Datum, keine Uhrzeit).
DEFAULT_CHECKIN_TIME=15:00
DEFAULT_CHECKOUT_TIME=11:00

# Port, auf dem der Server lauscht
PORT=3000
